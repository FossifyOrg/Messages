<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Pesan yang Diterima (Kiri) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_received_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="64dp"
        android:layout_marginBottom="4dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        style="@style/Widget.Messages.Card">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Teks Pesan -->
            <TextView
                android:id="@+id/thread_message_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello, how are you?"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:autoLink="email|web"
                tools:text="Hello, how are you?" />

            <!-- Waktu Pesan -->
            <TextView
                android:id="@+id/thread_message_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="10:30 AM"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="10sp"
                tools:text="10:30 AM" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Pesan yang Dikirim (Kanan) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_sent_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        style="@style/Widget.Messages.Card">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Teks Pesan -->
            <TextView
                android:id="@+id/thread_message_body_sent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I'm fine, thanks!"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="14sp"
                android:autoLink="email|web"
                tools:text="I'm fine, thanks!" />

            <!-- Status Pesan (Terkirim/Terbaca) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="end">

                <!-- Indikator Terkirim -->
                <ImageView
                    android:id="@+id/iv_sent_status"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_check"
                    android:tint="?attr/colorOnPrimaryContainer"
                    android:visibility="visible" />

                <!-- Indikator Terbaca -->
                <ImageView
                    android:id="@+id/iv_read_status"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/ic_check_all"
                    android:tint="?attr/colorOnPrimaryContainer"
                    android:visibility="gone" />

                <!-- Waktu Pesan -->
                <TextView
                    android:id="@+id/thread_message_time_sent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="10:31 AM"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="10sp"
                    tools:text="10:31 AM" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Pesan Sistem (Tengah) -->
    <TextView
        android:id="@+id/tv_system_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="8dp"
        android:background="?attr/colorSurfaceContainer"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="Message deleted"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"
        android:visibility="gone"
        app:cornerRadius="16dp"
        tools:text="Message deleted" />
</LinearLayout>